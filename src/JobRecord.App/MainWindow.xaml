<Window x:Class="JobRecord.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:core="clr-namespace:JobRecord.Core.Enums;assembly=JobRecord.Core"
        xmlns:viewModels="clr-namespace:JobRecord.App.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="工作时间记录"
        Width="460"
        MinWidth="280"
        MinHeight="56"
        SizeToContent="Height"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="OnLoaded"
        Closing="OnClosing"
        MouseEnter="OnMouseEnteredWindow"
        MouseLeave="OnMouseLeftWindow">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="WindowShellBrush" Color="#FFF2F7FA" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#FFF8FBFD" />
        <SolidColorBrush x:Key="SurfaceAccentBrush" Color="#FFF4F9FC" />
        <SolidColorBrush x:Key="BorderBrush" Color="#FFD4E0E7" />
        <SolidColorBrush x:Key="BorderStrongBrush" Color="#FF9EB9C7" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF11222C" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF5A6F7B" />
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FF83959F" />
        <SolidColorBrush x:Key="ActionPrimaryBrush" Color="#FF1F607C" />
        <SolidColorBrush x:Key="ActionPrimaryHoverBrush" Color="#FF184E65" />
        <SolidColorBrush x:Key="ActionPrimaryDisabledBrush" Color="#FF92AAB6" />
        <SolidColorBrush x:Key="ActionSecondaryBrush" Color="#FFF2F6F8" />
        <SolidColorBrush x:Key="ActionSecondaryHoverBrush" Color="#FFE6EEF2" />
        <SolidColorBrush x:Key="ActionSecondaryBorderBrush" Color="#FFCCD9E0" />
        <SolidColorBrush x:Key="ActionGhostHoverBrush" Color="#FFEAF2F7" />

        <effects:DropShadowEffect x:Key="ShellShadow"
                                  BlurRadius="18"
                                  ShadowDepth="0"
                                  Color="#440D2A38"
                                  Opacity="0.35" />

        <Style x:Key="CompactHiddenStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompact}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowShellCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WindowShellBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Effect" Value="{StaticResource ShellShadow}" />
        </Style>

        <Style x:Key="SideDockHostStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WindowShellBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Effect" Value="{StaticResource ShellShadow}" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="DragHandleStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{StaticResource SurfaceAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="SizeAll" />
        </Style>

        <Style x:Key="SideTimerPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="BodyMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource ActionPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ActionPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ActionPrimaryHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ActionPrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ActionPrimaryDisabledBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource ActionPrimaryDisabledBrush}" />
                                <Setter Property="Foreground" Value="#FFF3F7F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource ActionSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ActionSecondaryBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ActionSecondaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#FFF5F7F8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFE0E7EB" />
                                <Setter Property="Foreground" Value="#FF98A8B2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource ActionGhostHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF98A8B2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Background" Value="#FFF0F8FC" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopDockRootStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTopDocked}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LeftDockRootStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLeftDocked}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightDockRootStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRightDocked}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenEditingStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenViewingStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="TaskListItemTemplate">
            <Border Margin="0,0,0,8"
                    Padding="10"
                    Style="{StaticResource TaskCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Background="{Binding PrioritySoftBackground}"
                                    BorderBrush="{Binding PriorityBackground}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Padding="6,2"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{Binding PriorityText}"
                                           Foreground="{Binding PriorityBackground}"
                                           FontSize="11"
                                           FontWeight="Bold" />
                            </Border>
                            <Border Background="{Binding StatusBackground}"
                                    CornerRadius="9"
                                    Padding="6,2">
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{Binding StatusForeground}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding Title}"
                                   FontSize="14"
                                   Margin="0,0,0,5"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TitleTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Margin="0,0,0,6"
                                 Padding="8,5"
                                 Background="{StaticResource SurfaceMutedBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Text="{Binding EditableTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource VisibleWhenEditingStyle}" />

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DurationText}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas"
                                       FontWeight="SemiBold"
                                       Margin="0,0,12,0" />
                            <TextBlock Text="{Binding EstimateText}"
                                       Style="{StaticResource BodyMutedTextStyle}" />
                        </StackPanel>

                        <Grid Margin="0,9,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Padding="8,5"
                                     Background="{StaticResource SurfaceMutedBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Text="{Binding NewSubTaskTitle, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="6,0,0,0"
                                    MinWidth="48"
                                    Content="添加"
                                    IsEnabled="{Binding CanCreateSubTask}"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding DataContext.CreateSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding SubTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="0,6,0,0"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,0,0,3">
                                                    <Border Background="{Binding StatusBackground}"
                                                            CornerRadius="8"
                                                            Padding="5,1"
                                                            Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Foreground="{Binding StatusForeground}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <TextBlock Text="{Binding DurationText}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding CompletedAtText}"
                                                               Style="{StaticResource BodyMutedTextStyle}"
                                                               FontSize="11" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Top"
                                                        Margin="8,0,0,0">
                                                <Button MinWidth="42"
                                                        Margin="0,0,5,0"
                                                        Content="{Binding PrimaryActionText}"
                                                        IsEnabled="{Binding CanPrimaryAction}"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Command="{Binding DataContext.PrimarySubTaskActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                                <Button MinWidth="42"
                                                        Content="完成"
                                                        IsEnabled="{Binding CanComplete}"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Command="{Binding DataContext.CompleteSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                VerticalAlignment="Top"
                                Margin="12,0,0,0">
                        <Button Margin="0,0,0,6"
                                MinWidth="56"
                                Content="{Binding PrimaryActionText}"
                                IsEnabled="{Binding CanPrimaryAction}"
                                Command="{Binding DataContext.PrimaryTaskActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="0,0,0,6"
                                MinWidth="56"
                                Content="改名"
                                Command="{Binding DataContext.BeginEditTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button MinWidth="56"
                                Content="完成"
                                IsEnabled="{Binding CanComplete}"
                                Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Margin="0,0,0,6"
                                MinWidth="56"
                                Content="保存"
                                IsEnabled="{Binding CanSaveEdit}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding DataContext.SaveTaskEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button MinWidth="56"
                                Style="{StaticResource GhostButtonStyle}"
                                Content="取消"
                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding DataContext.CancelEditTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="CaptureRoot">
        <Border Style="{StaticResource TopDockRootStyle}"
                Padding="0">
            <Border Style="{StaticResource WindowShellCardStyle}">
                <StackPanel>
                    <Border Background="{Binding CurrentPanelBackground}"
                            BorderBrush="{Binding CurrentPanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource DragHandleStyle}"
                                    MouseLeftButtonDown="OnDragHandleMouseLeftButtonDown">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           FontWeight="Bold"
                                           Text="::" />
                            </Border>

                            <Border Grid.Column="1"
                                    Background="Transparent"
                                    Padding="2,1"
                                    MouseLeftButtonDown="OnHeaderContentMouseLeftButtonDown"
                                    MouseLeftButtonUp="OnHeaderContentMouseLeftButtonUp">
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Background="{Binding CurrentPriorityBackground}"
                                                CornerRadius="10"
                                                Padding="7,2"
                                                Margin="0,0,8,0"
                                                Visibility="{Binding HasCurrentTask, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding CurrentPriorityText}"
                                                       Foreground="{Binding CurrentPriorityForeground}"
                                                       FontSize="11"
                                                       FontWeight="Bold" />
                                        </Border>
                                        <Border Background="{Binding CurrentStatusBackground}"
                                                CornerRadius="10"
                                                Padding="7,2"
                                                Visibility="{Binding HasCurrentTask, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Style="{StaticResource CompactHiddenStyle}">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding CurrentStatusForeground}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding CurrentTaskTitle}"
                                               Style="{StaticResource TitleTextStyle}"
                                               FontSize="15"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Margin="18,0,10,0"
                                    Padding="10,6"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock Text="{Binding CurrentDurationText}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           FontWeight="Bold" />
                            </Border>

                            <Button Grid.Column="3"
                                    Margin="0,0,8,0"
                                    Content="{Binding WorkActionText}"
                                    Command="{Binding ToggleWorkStateCommand}"
                                    >
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="4"
                                    Content="完成"
                                    Command="{Binding CompleteCurrentTaskCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Margin="0,10,0,0"
                            Style="{StaticResource SectionCardStyle}"
                            Background="{StaticResource SurfaceMutedBrush}"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="当前进度"
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   Margin="0,0,0,2" />
                                        <TextBlock Text="{Binding TodaySummaryText}"
                                                   Style="{StaticResource TitleTextStyle}"
                                                   FontSize="14" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{Binding CurrentPrioritySoftBackground}"
                                            CornerRadius="12"
                                            Padding="10,5"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasCurrentTask, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding CurrentTaskTitle}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="快速开始"
                                               Style="{StaticResource TitleTextStyle}"
                                               FontSize="13"
                                               Margin="0,0,0,8" />
                                    <TextBox Margin="0,0,0,8"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             Padding="8,5"
                                             Background="{StaticResource SurfaceMutedBrush}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1"
                                             Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0"
                                                  Margin="0,0,8,0"
                                                  MinHeight="34"
                                                  Background="{StaticResource SurfaceMutedBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}"
                                                  BorderThickness="1"
                                                  SelectedValue="{Binding NewTaskPriority}"
